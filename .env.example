DEMO_USER_PASSWORD=ChangeMe123!

# Redis
REDIS_URL=redis://localhost:6379

# Billing
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_PRICE_BASIC_MONTHLY=price_basic_monthly_replace_me
STRIPE_PRICE_ADVANCED_MONTHLY=price_advanced_monthly_replace_me
STRIPE_PRICE_ELITE_MONTHLY=price_elite_monthly_replace_me
STRIPE_PRICE_ELITE_ANNUAL=price_elite_annual_replace_me

# AI insights
OPENAI_API_KEY=replace_me
